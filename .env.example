# Copy this file to .env and fill in real values before running the demo.
# Existing OS environment variables override values in this file.

# Required only when QUICKBASE_DEMO_EXECUTE=true or --execute is passed.
QUICKBASE_REALM_HOSTNAME=example.quickbase.com
# Paste the raw user token. The client also tolerates a leading "QB-USER-TOKEN ".
QUICKBASE_USER_TOKEN=replace-with-qb-user-token

# Demo behavior.
QUICKBASE_DEMO_EXECUTE=false
QUICKBASE_DEMO_APP_NAME=PTO Tracking Demo
QUICKBASE_DEMO_ASSIGN_TOKEN=true
QUICKBASE_DEMO_EXPORT_DIR=demo_exports
QUICKBASE_DEMO_CREATE_RELATIONSHIP=true

# Backup behavior. Keep disabled for first runs unless your backup settings are valid.
QUICKBASE_DEMO_AUTO_BACKUP=false
QUICKBASE_DEMO_BACKUP_METHOD=schema
QUICKBASE_DEMO_BACKUP_SOLUTION_ID=
QUICKBASE_DEMO_BACKUP_DIR=demo_backups
QUICKBASE_DEMO_BACKUP_FALLBACK_TO_CLONE=true

# Optional trustee showcase. Set both values to add one trustee after app creation.
QUICKBASE_DEMO_TRUSTEE_EMAIL=
QUICKBASE_DEMO_TRUSTEE_ROLE_ID=
